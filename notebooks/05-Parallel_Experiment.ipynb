   "source": [
    "# ============================================================\n",
    "# CELDA 4 — PRUEBA RÁPIDA (2 réplicas en paralelo)\n",
    "# Verifica que el sandboxing funciona antes de lanzar todo\n",
    "# ============================================================\n",
    "\n",
    "print(\"🧪 Prueba: 2 réplicas en paralelo sobre worker_0 y worker_1...\")\n",
    "\n",
    "test_config = EXPERIMENT_CONFIGS[0]  # primer YAML disponible\n",
    "\n",
    "with ThreadPoolExecutor(max_workers=2) as pool:\n",
    "    futures = [\n",
    "        pool.submit(run_lgs_in_sandbox, WORKER_PATHS[0], test_config, 'test_A'),\n",
    "        pool.submit(run_lgs_in_sandbox, WORKER_PATHS[1], test_config, 'test_B'),\n",
    "    ]\n",
    "    for f in as_completed(futures):\n",
    "        r = f.result()\n",
    "        sym = '✅' if r['success'] else '❌'\n",
    "        print(f\"   {sym} réplica {r['replica']}  |  \"\n",
    "              f\"config={r['config']}  |  t_gen={r['t_gen']}s\")\n",
    "\n",
    "print()\n",
    "if all(f.result()['success'] for f in futures):\n",
    "    print(\"✅ Sandboxing funciona correctamente\")\n",
    "    print(\"🚀 Listo para el experimento completo (Celda 5)\")\n",
    "else:\n",
    "    print(\"❌ Algo falló — revisa los errores antes de continuar\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELDA 5 — EXPERIMENTO PARALELO COMPLETO\n",
    "# 8 workers simultáneos, guardado thread-safe al CSV\n",
    "# ============================================================\n",
    "\n",
    "# Construir la lista completa de tareas\n",
    "# Cada tarea es (worker_idx, config_file, replica_num)\n",
    "tasks = []\n",
    "for config_file in EXPERIMENT_CONFIGS:\n",
    "    for rep in range(1, N_REPLICAS + 1):\n",
    "        # Asignar workers en round-robin para distribuir carga\n",
    "        worker_idx = (len(tasks)) % N_WORKERS\n",
    "        tasks.append((WORKER_PATHS[worker_idx], config_file, rep))\n",
    "\n",
    "# Mezclar para que los workers no corran todos el mismo config a la vez\n",
    "import random\n",
    "random.shuffle(tasks)\n",
    "\n",
    "# Abrir CSV (thread-safe via lock)\n",
    "csv_fields = list(CONFIG_META[next(iter(CONFIG_META))].keys()) + \\\n",
    "             ['config','replica','t_gen','success','error','timestamp']\n",
    "# Campos ordenados para el CSV\n",
    "if EXPERIMENT_MODE == 'EXP1':\n",
    "    csv_fields = ['config','group','dp','fBO4','sg_ratio',\n",
    "                  'replica','t_gen','success','error','timestamp']\n",
    "else:\n",
    "    csv_fields = ['config','fbo4_source','fBO4','sg_ratio','dp',\n",
    "                  'replica','t_gen','success','error','timestamp']\n",
    "\n",
    "csv_exists = os.path.exists(RESULTS_CSV)\n",
    "csv_file   = open(RESULTS_CSV, 'a', newline='')\n",
    "writer     = csv.DictWriter(csv_file, fieldnames=csv_fields)\n",
    "if not csv_exists:\n",
    "    writer.writeheader()\n",
    "\n",
    "# Contadores compartidos (thread-safe)\n",
    "done_count   = [0]       # lista para mutabilidad desde hilos\n",
    "success_count = [0]\n",
    "total_tasks  = len(tasks)\n",
    "t0           = time.time()\n",
    "\n",
    "def run_task(args):\n",
    "    \"\"\"Función que corre cada tarea y escribe al CSV de forma segura.\"\"\"\n",
    "    worker_path, config_file, rep = args\n",
    "    config_name = os.path.basename(config_file).replace('_config.yaml','')\n",
    "    meta = CONFIG_META.get(config_name, {})\n",
    "\n",
    "    r = run_lgs_in_sandbox(worker_path, config_file, rep)\n",
    "\n",
    "    row = {**meta,\n",
    "           'config':    r['config'],\n",
    "           'replica':   r['replica'],\n",
    "           't_gen':     r['t_gen'] if r['t_gen'] else '',\n",
    "           'success':   r['success'],\n",
    "           'error':     r['error'],\n",
    "           'timestamp': r['timestamp']}\n",
    "\n",
    "    # Escritura thread-safe\n",
    "    with csv_lock:\n",
    "        writer.writerow(row)\n",
    "        csv_file.flush()\n",
    "        done_count[0]   += 1\n",
    "        success_count[0] += int(r['success'])\n",
    "        pct = done_count[0] / total_tasks * 100\n",
    "        elapsed = time.time() - t0\n",
    "        eta = (elapsed / done_count[0]) * (total_tasks - done_count[0])\n",
    "        print(f\"\\r  [{done_count[0]:>3}/{total_tasks}] {pct:.0f}%  \"\n",
    "              f\"✅{success_count[0]}  \"\n",
    "              f\"Elapsed: {elapsed/60:.1f}m  ETA: {eta/60:.1f}m  \"\n",
    "              f\"| {r['config']} rep{rep} → {r['t_gen']}s\",\n",
    "              end='', flush=True)\n",
    "\n",
    "    return r\n",
    "\n",
    "print(f\"🚀 EXPERIMENTO PARALELO — {EXPERIMENT_MODE}\")\n",
    "print(f\"   Workers activos: {N_WORKERS}\")\n",
    "print(f\"   Tareas totales:  {total_tasks}\")\n",
    "print(f\"   CSV → {RESULTS_CSV}\")\n",
    "print(\"-\" * 60)\n",
    "\n",
    "with ThreadPoolExecutor(max_workers=N_WORKERS) as pool:\n",
    "    futures = [pool.submit(run_task, t) for t in tasks]\n",
    "    # Esperar a que terminen todas\n",
    "    for _ in as_completed(futures):\n",
    "        pass\n",
    "\n",
    "csv_file.close()\n",
    "\n",
    "t_total = time.time() - t0\n",
    "print(f\"\\n\\n{'='*60}\")\n",
    "print(f\"✅ EXPERIMENTO COMPLETO\")\n",
    "print(f\"   Tiempo total:    {t_total/60:.1f} minutos\")\n",
    "print(f\"   Corridas OK:     {success_count[0]}/{total_tasks}\")\n",
    "print(f\"   CSV guardado en: {RESULTS_CSV}\")"
   ]
  },
  {
   "cell_type": "code",
