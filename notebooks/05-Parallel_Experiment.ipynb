   "source": [
    "# ============================================================\n",
    "# CELDA 6 — RESUMEN DE RESULTADOS\n",
    "# Igual que en notebooks 03 y 04 pero funciona para ambos modos\n",
    "# ============================================================\n",
    "import csv\n",
    "from collections import defaultdict\n",
    "\n",
    "data = defaultdict(list)\n",
    "\n",
    "with open(RESULTS_CSV) as f:\n",
    "    for row in csv.DictReader(f):\n",
    "        if row['success'] == 'True' and row['t_gen']:\n",
    "            if EXPERIMENT_MODE == 'EXP1':\n",
    "                key = (row['group'], int(row['dp']))\n",
    "            else:\n",
    "                key = (float(row['fBO4']), float(row['sg_ratio']))\n",
    "            data[key].append(float(row['t_gen']))\n",
    "\n",
    "def stats(vals):\n",
    "    n    = len(vals)\n",
    "    mean = sum(vals)/n\n",
    "    sd   = (sum((x-mean)**2 for x in vals)/n)**0.5\n",
    "    return n, mean, sd, min(vals), max(vals)\n",
    "\n",
    "if EXPERIMENT_MODE == 'EXP1':\n",
    "    print(f\"{'Grupo':<6} {'DP':>4} {'n':>4} {'Media (s)':>10} {'SD':>7} {'Min':>7} {'Max':>7}\")\n",
    "    print(\"-\" * 48)\n",
    "    for group in ['SW','HW','GR']:\n",
    "        for dp in [5, 8, 10]:\n",
    "            vals = data.get((group, dp), [])\n",
    "            if vals:\n",
    "                n,m,s,mn,mx = stats(vals)\n",
    "                print(f\"{group:<6} {dp:>4} {n:>4} {m:>10.2f} {s:>7.2f} {mn:>7.2f} {mx:>7.2f}\")\n",
    "else:\n",
    "    print(f\"{'fBO4':>6} {'S/G':>6} {'n':>4} {'Media (s)':>10} {'SD':>7}\")\n",
    "    print(\"-\" * 38)\n",
    "    for fbo4 in [0.54, 0.69, 0.77]:\n",
    "        for sg in [0.0, 0.8, 1.5]:\n",
    "            vals = data.get((fbo4, sg), [])\n",
    "            if vals:\n",
    "                n,m,s,mn,mx = stats(vals)\n",
    "                print(f\"{fbo4:>6.2f} {sg:>6.1f} {n:>4} {m:>10.2f} {s:>7.2f}\")\n",
    "\n",
    "    # Efectos principales\n",
    "    print(\"\\nEFECTO de fBO4 (promedio sobre S/G):\")\n",
    "    for fbo4 in [0.54, 0.69, 0.77]:\n",
    "        all_v = [v for sg in [0.0,0.8,1.5] for v in data.get((fbo4,sg),[])]\n",
    "        if all_v:\n",
    "            print(f\"  fBO4={fbo4}: {sum(all_v)/len(all_v):.2f}s\")\n",
    "\n",
    "    print(\"\\nEFECTO de S/G (promedio sobre fBO4):\")\n",
    "    for sg in [0.0, 0.8, 1.5]:\n",
    "        all_v = [v for fbo4 in [0.54,0.69,0.77] for v in data.get((fbo4,sg),[])]\n",
    "        if all_v:\n",
    "            print(f\"  S/G={sg}: {sum(all_v)/len(all_v):.2f}s\")"
   ]
  },
