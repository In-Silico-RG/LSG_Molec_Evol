   "source": [
    "# Experimento Paralelo — 8 workers simultáneos\n",
    "## Notebook 05 — Versión paralela de los Experimentos 1 y 2\n",
    "\n",
    "**Estrategia:** Cada worker tiene su propio sandbox con `lgs_gen.jar`, `resources/` y `output/`  \n",
    "Sin conflicto de archivos. Speedup real ~4-6x sobre la versión secuencial.\n",
    "\n",
    "**Uso:** Cambia `EXPERIMENT_MODE` en la Celda 1 para elegir qué experimento correr:\n",
    "- `'EXP1'` → Experimento 1 (SW/HW/GR × DP5/8/10)\n",
    "- `'EXP2'` → Experimento 2 (desacople fBO4 × S/G, DP=10)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELDA 1 — CONFIGURACIÓN\n",
    "# ============================================================\n",
    "import os, subprocess, shutil, time, glob, csv, threading\n",
    "from datetime import datetime\n",
    "from concurrent.futures import ThreadPoolExecutor, as_completed\n",
    "from queue import Queue\n",
    "\n",
    "# ── AJUSTA ESTAS VARIABLES ────────────────────────────────\n",
    "BASE_PATH       = \"/media/aldo/Aldo/sims/Lignin_DB_Chemically_Real-5\"\n",
    "N_WORKERS       = 8       # hilos de procesamiento\n",
    "N_REPLICAS      = 30      # réplicas por configuración\n",
    "EXPERIMENT_MODE = 'EXP2'  # 'EXP1' o 'EXP2'\n",
    "# ──────────────────────────────────────────────────────────\n",
    "\n",
    "JAR_PATH      = os.path.join(BASE_PATH, \"lgs_gen.jar\")\n",
    "RESOURCES_DIR = os.path.join(BASE_PATH, \"resources\")\n",
    "WORKERS_DIR   = os.path.join(BASE_PATH, \"workers\")\n",
    "\n",
    "if EXPERIMENT_MODE == 'EXP1':\n",
    "    RESULTS_CSV = os.path.join(BASE_PATH, \"exp1_parallel_results.csv\")\n",
    "    CONFIG_PATTERN = [\"SW_DP*\", \"HW_DP*\", \"GR_DP*\"]\n",
    "    CONFIG_META = {\n",
    "        'SW_DP5':  {'group':'SW','dp':5, 'fBO4':0.54,'sg_ratio':0.0},\n",
    "        'SW_DP8':  {'group':'SW','dp':8, 'fBO4':0.54,'sg_ratio':0.0},\n",
    "        'SW_DP10': {'group':'SW','dp':10,'fBO4':0.54,'sg_ratio':0.0},\n",
    "        'HW_DP5':  {'group':'HW','dp':5, 'fBO4':0.69,'sg_ratio':1.5},\n",
    "        'HW_DP8':  {'group':'HW','dp':8, 'fBO4':0.69,'sg_ratio':1.5},\n",
    "        'HW_DP10': {'group':'HW','dp':10,'fBO4':0.69,'sg_ratio':1.5},\n",
    "        'GR_DP5':  {'group':'GR','dp':5, 'fBO4':0.77,'sg_ratio':0.8},\n",
    "        'GR_DP8':  {'group':'GR','dp':8, 'fBO4':0.77,'sg_ratio':0.8},\n",
    "        'GR_DP10': {'group':'GR','dp':10,'fBO4':0.77,'sg_ratio':0.8},\n",
    "    }\n",
    "else:  # EXP2\n",
    "    RESULTS_CSV = os.path.join(BASE_PATH, \"exp2_parallel_results.csv\")\n",
    "    CONFIG_PATTERN = [\"SW_fBO4_*\", \"HW_fBO4_*\", \"GR_fBO4_*\"]\n",
    "    CONFIG_META = {\n",
    "        'SW_fBO4_sg0':  {'fbo4_source':'SW','fBO4':0.54,'sg_ratio':0.0,'dp':10},\n",
    "        'SW_fBO4_sg15': {'fbo4_source':'SW','fBO4':0.54,'sg_ratio':1.5,'dp':10},\n",
    "        'SW_fBO4_sg08': {'fbo4_source':'SW','fBO4':0.54,'sg_ratio':0.8,'dp':10},\n",
    "        'HW_fBO4_sg0':  {'fbo4_source':'HW','fBO4':0.69,'sg_ratio':0.0,'dp':10},\n",
    "        'HW_fBO4_sg15': {'fbo4_source':'HW','fBO4':0.69,'sg_ratio':1.5,'dp':10},\n",
    "        'HW_fBO4_sg08': {'fbo4_source':'HW','fBO4':0.69,'sg_ratio':0.8,'dp':10},\n",
    "        'GR_fBO4_sg0':  {'fbo4_source':'GR','fBO4':0.77,'sg_ratio':0.0,'dp':10},\n",
    "        'GR_fBO4_sg15': {'fbo4_source':'GR','fBO4':0.77,'sg_ratio':1.5,'dp':10},\n",
    "        'GR_fBO4_sg08': {'fbo4_source':'GR','fBO4':0.77,'sg_ratio':0.8,'dp':10},\n",
    "    }\n",
    "\n",
    "# Encontrar YAMLs\n",
    "EXPERIMENT_CONFIGS = []\n",
    "for pat in CONFIG_PATTERN:\n",
    "    EXPERIMENT_CONFIGS.extend(sorted(glob.glob(\n",
    "        os.path.join(RESOURCES_DIR, pat + \"_config.yaml\"))))\n",
    "\n",
    "assert os.path.exists(JAR_PATH), f\"❌ lgs_gen.jar no encontrado\"\n",
    "assert len(EXPERIMENT_CONFIGS) == 9, (\n",
    "    f\"❌ Se esperaban 9 YAMLs, encontré {len(EXPERIMENT_CONFIGS)}. \"\n",
    "    f\"Verifica que copiaste los archivos a resources/\")\n",
    "\n",
    "total = len(EXPERIMENT_CONFIGS) * N_REPLICAS\n",
    "print(f\"✅ Configuración lista\")\n",
    "print(f\"   Modo:        {EXPERIMENT_MODE}\")\n",
    "print(f\"   Workers:     {N_WORKERS}\")\n",
    "print(f\"   Configs:     {len(EXPERIMENT_CONFIGS)}\")\n",
    "print(f\"   Réplicas:    {N_REPLICAS}\")\n",
    "print(f\"   Total runs:  {total}\")\n",
    "print(f\"   CSV:         {RESULTS_CSV}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELDA 2 — CREAR SANDBOXES\n",
    "# Cada worker tiene su propio directorio aislado\n",
    "# ============================================================\n",
    "\n",
    "def setup_workers(base_path, jar_path, n_workers):\n",
    "    \"\"\"Crea N directorios de trabajo aislados para paralelismo seguro.\"\"\"\n",
    "    workers_dir = os.path.join(base_path, \"workers\")\n",
    "    worker_paths = []\n",
    "\n",
    "    for i in range(n_workers):\n",
    "        wp = os.path.join(workers_dir, f\"worker_{i}\")\n",
    "        res_dir = os.path.join(wp, \"resources\")\n",
    "        out_dir = os.path.join(wp, \"output\")\n",
    "\n",
    "        os.makedirs(res_dir, exist_ok=True)\n",
    "        os.makedirs(out_dir, exist_ok=True)\n",
    "\n",
    "        # Symlink al jar (evita copiar el archivo grande)\n",
    "        jar_link = os.path.join(wp, \"lgs_gen.jar\")\n",
    "        if not os.path.exists(jar_link):\n",
    "            os.symlink(jar_path, jar_link)\n",
    "\n",
    "        worker_paths.append(wp)\n",
    "\n",
    "    return worker_paths\n",
    "\n",
    "WORKER_PATHS = setup_workers(BASE_PATH, JAR_PATH, N_WORKERS)\n",
    "print(f\"✅ {N_WORKERS} sandboxes creados en {WORKERS_DIR}\")\n",
    "for i, wp in enumerate(WORKER_PATHS):\n",
    "    print(f\"   worker_{i}: {wp}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELDA 3 — FUNCIÓN DE CORRIDA EN SANDBOX\n",
    "# Cada worker usa su propio directorio → sin conflicto\n",
    "# ============================================================\n",
    "\n",
    "# Lock para escritura segura al CSV desde múltiples hilos\n",
    "csv_lock = threading.Lock()\n",
    "\n",
    "def run_lgs_in_sandbox(worker_path, config_file, replica_num):\n",
    "    \"\"\"\n",
    "    Corre LGS en un sandbox aislado.\n",
    "    worker_path: directorio exclusivo de este hilo\n",
    "    config_file: YAML del experimento a usar\n",
    "    replica_num: número de réplica (solo para logging)\n",
    "    \"\"\"\n",
    "    config_name   = os.path.basename(config_file).replace('_config.yaml', '')\n",
    "    jar_path      = os.path.join(worker_path, \"lgs_gen.jar\")\n",
    "    project_cfg   = os.path.join(worker_path, \"resources\", \"project_config.yaml\")\n",
    "    output_dir    = os.path.join(worker_path, \"output\")\n",
    "\n",
    "    t_gen, success, error_msg = None, False, \"\"\n",
    "\n",
    "    try:\n",
    "        # Copiar YAML al sandbox de este worker\n",
    "        shutil.copy2(config_file, project_cfg)\n",
    "\n",
    "        # Medir t_gen\n",
    "        t_start = time.time()\n",
    "        result  = subprocess.run(\n",
    "            [\"java\", \"-jar\", jar_path],\n",
    "            capture_output=True,\n",
    "            text=True,\n",
    "            cwd=worker_path        # cada worker en su propio cwd\n",
    "        )\n",
    "        t_gen   = time.time() - t_start\n",
    "        success = (result.returncode == 0)\n",
    "        if not success:\n",
    "            error_msg = result.stderr[:200]\n",
    "\n",
    "    except Exception as e:\n",
    "        error_msg = str(e)\n",
    "\n",
    "    finally:\n",
    "        # Limpiar outputs del sandbox (solo guardamos t_gen)\n",
    "        for folder in ['json', 'mol', 'struct', 'matrices']:\n",
    "            p = os.path.join(output_dir, folder)\n",
    "            if os.path.exists(p):\n",
    "                shutil.rmtree(p)\n",
    "        if os.path.exists(project_cfg):\n",
    "            os.remove(project_cfg)\n",
    "\n",
    "    return {\n",
    "        'config':    config_name,\n",
    "        'replica':   replica_num,\n",
    "        't_gen':     round(t_gen, 4) if t_gen else None,\n",
    "        'success':   success,\n",
    "        'error':     error_msg,\n",
    "        'timestamp': datetime.now().isoformat()\n",
    "    }\n",
    "\n",
    "print(\"✅ Función run_lgs_in_sandbox definida\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
