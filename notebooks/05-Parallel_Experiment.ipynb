    "# ============================================================\n",
    "# CELDA 7 — LIMPIEZA DE SANDBOXES (opcional)\n",
    "# Borra los directorios worker_N cuando ya no se necesiten\n",
    "# ============================================================\n",
    "respuesta = input(\"¿Eliminar los directorios de workers? (s/n): \")\n",
    "if respuesta.lower() == 's':\n",
    "    shutil.rmtree(WORKERS_DIR)\n",
    "    print(f\"✅ {WORKERS_DIR} eliminado\")\n",
    "else:\n",
    "    print(\"Workers conservados para futuras corridas\")"
   ]
