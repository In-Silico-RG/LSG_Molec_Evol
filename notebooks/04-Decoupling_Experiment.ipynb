    "# Experimento 2: Desacople fBO4 × S/G\n",
    "## Notebook 04 — DP fijo = 10, grilla 3×3\n",
    "\n",
    "**Pregunta:** ¿Es fBO4 o S/G el driver dominante de t_gen?\n",
    "\n",
    "**Diseño:** 3 niveles de fBO4 × 3 niveles de S/G × 30 réplicas = 270 corridas  \n",
    "DP fijo = 10 (el nivel donde las diferencias son más grandes)\n",
    "\n",
    "**Prerequisito:** Copiar los 9 YAMLs de `experiment2_yamls/` a `resources/`\n",
    "\n",
    "| | S/G = 0.0 (SW) | S/G = 1.5 (HW) | S/G = 0.8 (GR) |\n",
    "|---|---|---|---|\n",
    "| **fBO4 = 0.54 (SW)** | A1 control SW | A2 | A3 |\n",
    "| **fBO4 = 0.69 (HW)** | B1 | B2 control HW | B3 |\n",
    "| **fBO4 = 0.77 (GR)** | C1 | C2 | C3 control GR |"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELDA 1 — CONFIGURACIÓN\n",
    "# ============================================================\n",
    "import os, subprocess, shutil, time, glob, csv\n",
    "from datetime import datetime\n",
    "\n",
    "# ── AJUSTA ESTA RUTA ──────────────────────────────────────\n",
    "BASE_PATH = \"/media/aldo/Aldo/sims/Lignin_DB_Chemically_Real-5\"\n",
    "# ──────────────────────────────────────────────────────────\n",
    "\n",
    "N_REPLICAS    = 30\n",
    "JAR_PATH      = os.path.join(BASE_PATH, \"lgs_gen.jar\")\n",
    "RESOURCES_DIR = os.path.join(BASE_PATH, \"resources\")\n",
    "OUTPUT_DIR    = os.path.join(BASE_PATH, \"output\")\n",
    "RESULTS_CSV   = os.path.join(BASE_PATH, \"decoupling_experiment_results.csv\")\n",
    "\n",
    "assert os.path.exists(JAR_PATH), f\"❌ lgs_gen.jar no encontrado en {JAR_PATH}\"\n",
    "\n",
    "# Los 9 YAMLs del experimento 2\n",
    "EXPERIMENT_CONFIGS = sorted(\n",
    "    glob.glob(os.path.join(RESOURCES_DIR, \"SW_fBO4_*_config.yaml\")) +\n",
    "    glob.glob(os.path.join(RESOURCES_DIR, \"HW_fBO4_*_config.yaml\")) +\n",
    "    glob.glob(os.path.join(RESOURCES_DIR, \"GR_fBO4_*_config.yaml\"))\n",
    ")\n",
    "\n",
    "print(f\"✅ lgs_gen.jar encontrado\")\n",
    "print(f\"📋 Configuraciones encontradas: {len(EXPERIMENT_CONFIGS)}\")\n",
    "for f in EXPERIMENT_CONFIGS:\n",
    "    print(f\"   • {os.path.basename(f)}\")\n",
    "\n",
    "if len(EXPERIMENT_CONFIGS) != 9:\n",
    "    print(\"\\n⚠️  Se esperaban 9 YAMLs. Verifica que copiaste los archivos a resources/\")\n",
    "else:\n",
    "    total = len(EXPERIMENT_CONFIGS) * N_REPLICAS\n",
    "    print(f\"\\n✅ Listo. {len(EXPERIMENT_CONFIGS)} configs × {N_REPLICAS} réplicas = {total} corridas\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELDA 2 — FUNCIÓN DE CORRIDA (idéntica al Notebook 03)\n",
    "# ============================================================\n",
    "def run_lgs_once(config_file, replica_num):\n",
    "    project_config = os.path.join(RESOURCES_DIR, \"project_config.yaml\")\n",
    "    backup = None\n",
    "    if os.path.exists(project_config):\n",
    "        backup = project_config + \".backup\"\n",
    "        shutil.move(project_config, backup)\n",
    "\n",
    "    t_gen, success, error_msg = None, False, \"\"\n",
    "    try:\n",
    "        shutil.copy2(config_file, project_config)\n",
    "        t_start = time.time()\n",
    "        result  = subprocess.run(\n",
    "            [\"java\", \"-jar\", JAR_PATH],\n",
    "            capture_output=True, text=True, cwd=BASE_PATH\n",
    "        )\n",
    "        t_gen   = time.time() - t_start\n",
    "        success = (result.returncode == 0)\n",
    "        if not success:\n",
    "            error_msg = result.stderr[:200]\n",
    "    except Exception as e:\n",
    "        error_msg = str(e)\n",
    "    finally:\n",
    "        if os.path.exists(project_config):\n",
    "            os.remove(project_config)\n",
    "        if backup and os.path.exists(backup):\n",
    "            shutil.move(backup, project_config)\n",
    "        for folder in ['json', 'mol', 'struct', 'matrices']:\n",
    "            p = os.path.join(OUTPUT_DIR, folder)\n",
    "            if os.path.exists(p):\n",
    "                shutil.rmtree(p)\n",
    "\n",
    "    return {\n",
    "        'config':    os.path.basename(config_file).replace('_config.yaml',''),\n",
    "        'replica':   replica_num,\n",
    "        't_gen':     t_gen,\n",
    "        'success':   success,\n",
    "        'error':     error_msg,\n",
    "        'timestamp': datetime.now().isoformat()\n",
    "    }\n",
    "\n",
    "print(\"✅ Función run_lgs_once definida\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELDA 3 — PRUEBA RÁPIDA (1 réplica)\n",
    "# ============================================================\n",
    "test = [f for f in EXPERIMENT_CONFIGS if 'SW_fBO4_sg0' in f]\n",
    "if not test:\n",
    "    print(\"❌ No encontré SW_fBO4_sg0_config.yaml en resources/\")\n",
    "else:\n",
    "    print(\"🧪 Prueba con SW_fBO4_sg0 (control SW, 1 réplica)...\")\n",
    "    r = run_lgs_once(test[0], 0)\n",
    "    if r['success']:\n",
    "        print(f\"✅ Prueba exitosa  |  t_gen = {r['t_gen']:.2f}s\")\n",
    "        print(f\"\\n🚀 Listo para el experimento completo (Celda 4)\")\n",
    "    else:\n",
    "        print(f\"❌ Error: {r['error']}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CELDA 4 — EXPERIMENTO COMPLETO (270 corridas)\n",
    "# ============================================================\n",
    "\n",
    "# Metadatos de cada configuración para el CSV\n",
    "CONFIG_META = {\n",
    "    'SW_fBO4_sg0':  {'fbo4_source':'SW', 'fBO4':0.54, 'sg_ratio':0.0, 'dp':10},\n",
    "    'SW_fBO4_sg15': {'fbo4_source':'SW', 'fBO4':0.54, 'sg_ratio':1.5, 'dp':10},\n",
    "    'SW_fBO4_sg08': {'fbo4_source':'SW', 'fBO4':0.54, 'sg_ratio':0.8, 'dp':10},\n",
    "    'HW_fBO4_sg0':  {'fbo4_source':'HW', 'fBO4':0.69, 'sg_ratio':0.0, 'dp':10},\n",
    "    'HW_fBO4_sg15': {'fbo4_source':'HW', 'fBO4':0.69, 'sg_ratio':1.5, 'dp':10},\n",
    "    'HW_fBO4_sg08': {'fbo4_source':'HW', 'fBO4':0.69, 'sg_ratio':0.8, 'dp':10},\n",
    "    'GR_fBO4_sg0':  {'fbo4_source':'GR', 'fBO4':0.77, 'sg_ratio':0.0, 'dp':10},\n",
    "    'GR_fBO4_sg15': {'fbo4_source':'GR', 'fBO4':0.77, 'sg_ratio':1.5, 'dp':10},\n",
    "    'GR_fBO4_sg08': {'fbo4_source':'GR', 'fBO4':0.77, 'sg_ratio':0.8, 'dp':10},\n",
    "}\n",
    "\n",
    "CSV_FIELDS = ['config','fbo4_source','fBO4','sg_ratio','dp',\n",
    "              'replica','t_gen','success','error','timestamp']\n",
    "\n",
    "csv_exists = os.path.exists(RESULTS_CSV)\n",
    "csv_file   = open(RESULTS_CSV, 'a', newline='')\n",
    "writer     = csv.DictWriter(csv_file, fieldnames=CSV_FIELDS)\n",
    "if not csv_exists:\n",
    "    writer.writeheader()\n",
    "\n",
    "total = len(EXPERIMENT_CONFIGS) * N_REPLICAS\n",
    "done  = 0\n",
    "t0    = time.time()\n",
    "\n",
    "print(f\"🚀 EXPERIMENTO 2 — DESACOPLE fBO4 × S/G\")\n",
    "print(f\"   Total de corridas: {total}\")\n",
    "print(f\"   Resultados → {RESULTS_CSV}\")\n",
    "print(\"-\" * 60)\n",
    "\n",
    "for config_file in EXPERIMENT_CONFIGS:\n",
    "    config_name = os.path.basename(config_file).replace('_config.yaml','')\n",
    "    meta = CONFIG_META.get(config_name, {})\n",
    "    t_list = []\n",
    "\n",
    "    print(f\"\\n📦 {config_name}  \"\n",
    "          f\"(fBO4={meta.get('fBO4','?')}, S/G={meta.get('sg_ratio','?')})\")\n",
    "\n",
    "    for rep in range(1, N_REPLICAS + 1):\n",
    "        r = run_lgs_once(config_file, rep)\n",
    "\n",
    "        row = {\n",
    "            'config':      r['config'],\n",
    "            'fbo4_source': meta.get('fbo4_source',''),\n",
    "            'fBO4':        meta.get('fBO4',''),\n",
    "            'sg_ratio':    meta.get('sg_ratio',''),\n",
    "            'dp':          meta.get('dp',''),\n",
    "            'replica':     r['replica'],\n",
    "            't_gen':       round(r['t_gen'], 4) if r['t_gen'] else '',\n",
    "            'success':     r['success'],\n",
    "            'error':       r['error'],\n",
    "            'timestamp':   r['timestamp']\n",
    "        }\n",
    "        writer.writerow(row)\n",
    "        csv_file.flush()\n",
    "\n",
    "        if r['success'] and r['t_gen']:\n",
    "            t_list.append(r['t_gen'])\n",
    "\n",
    "        done += 1\n",
    "        sym  = '✅' if r['success'] else '❌'\n",
    "        ts   = f\"{r['t_gen']:.1f}s\" if r['t_gen'] else 'N/A'\n",
    "        print(f\"   {sym} Rep {rep:02d}/{N_REPLICAS}  t_gen={ts}  \"\n",
    "              f\"[{done/total*100:.0f}% global]\", end='\\r')\n",
    "\n",
    "    if t_list:\n",
    "        mean = sum(t_list)/len(t_list)\n",
    "        sd   = (sum((x-mean)**2 for x in t_list)/len(t_list))**0.5\n",
    "        print(f\"   ✅ {len(t_list)}/{N_REPLICAS} exitosas  \"\n",
    "              f\"t_gen = {mean:.2f} ± {sd:.2f} s\")\n",
    "\n",
    "csv_file.close()\n",
    "print(f\"\\n{'='*60}\")\n",
    "print(f\"✅ COMPLETO  |  Tiempo total: {(time.time()-t0)/60:.1f} min\")\n",
    "print(f\"   CSV → {RESULTS_CSV}\")"
   ]
  },
  {
