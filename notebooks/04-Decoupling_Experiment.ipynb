   "source": [
    "# ============================================================\n",
    "# CELDA 5 — ANÁLISIS: ¿quién manda, fBO4 o S/G?\n",
    "# ============================================================\n",
    "import csv\n",
    "from collections import defaultdict\n",
    "\n",
    "data = defaultdict(list)\n",
    "with open(RESULTS_CSV) as f:\n",
    "    for row in csv.DictReader(f):\n",
    "        if row['success'] == 'True' and row['t_gen']:\n",
    "            key = (float(row['fBO4']), float(row['sg_ratio']))\n",
    "            data[key].append(float(row['t_gen']))\n",
    "\n",
    "fbo4_levels = [0.54, 0.69, 0.77]\n",
    "sg_levels   = [0.0,  0.8,  1.5]\n",
    "labels_fbo4 = {0.54:'SW', 0.69:'HW', 0.77:'GR'}\n",
    "labels_sg   = {0.0:'SW', 0.8:'GR', 1.5:'HW'}\n",
    "\n",
    "# ── Tabla completa ──────────────────────────────────────────\n",
    "print(\"TABLA DE MEDIAS t_gen (segundos)\")\n",
    "print(f\"{'':>12}  {'S/G=0.0':>10}  {'S/G=0.8':>10}  {'S/G=1.5':>10}\")\n",
    "print(\"-\" * 50)\n",
    "for fbo4 in fbo4_levels:\n",
    "    row_str = f\"fBO4={fbo4} ({labels_fbo4[fbo4]})  \"\n",
    "    for sg in sg_levels:\n",
    "        vals = data.get((fbo4, sg), [])\n",
    "        mean = sum(vals)/len(vals) if vals else float('nan')\n",
    "        row_str += f\"{mean:>10.2f}  \"\n",
    "    print(row_str)\n",
    "\n",
    "# ── Efecto principal de fBO4 (promediando sobre S/G) ────────\n",
    "print(\"\\nEFECTO PRINCIPAL de fBO4 (promedio sobre todos los S/G):\")\n",
    "for fbo4 in fbo4_levels:\n",
    "    all_vals = []\n",
    "    for sg in sg_levels:\n",
    "        all_vals.extend(data.get((fbo4, sg), []))\n",
    "    if all_vals:\n",
    "        m = sum(all_vals)/len(all_vals)\n",
    "        print(f\"  fBO4={fbo4} ({labels_fbo4[fbo4]}):  {m:.2f}s\")\n",
    "\n",
    "# ── Efecto principal de S/G (promediando sobre fBO4) ────────\n",
    "print(\"\\nEFECTO PRINCIPAL de S/G (promedio sobre todos los fBO4):\")\n",
    "for sg in sg_levels:\n",
    "    all_vals = []\n",
    "    for fbo4 in fbo4_levels:\n",
    "        all_vals.extend(data.get((fbo4, sg), []))\n",
    "    if all_vals:\n",
    "        m = sum(all_vals)/len(all_vals)\n",
    "        print(f\"  S/G={sg} ({labels_sg[sg]}):  {m:.2f}s\")\n",
    "\n",
    "# ── Diagnóstico del driver dominante ────────────────────────\n",
    "print(\"\\nDIAGNÓSTICO:\")\n",
    "means_fbo4 = []\n",
    "for fbo4 in fbo4_levels:\n",
    "    all_vals = [v for sg in sg_levels for v in data.get((fbo4,sg),[])]\n",
    "    means_fbo4.append(sum(all_vals)/len(all_vals) if all_vals else 0)\n",
    "range_fbo4 = max(means_fbo4) - min(means_fbo4)\n",
    "\n",
    "means_sg = []\n",
    "for sg in sg_levels:\n",
    "    all_vals = [v for fbo4 in fbo4_levels for v in data.get((fbo4,sg),[])]\n",
    "    means_sg.append(sum(all_vals)/len(all_vals) if all_vals else 0)\n",
    "range_sg = max(means_sg) - min(means_sg)\n",
    "\n",
    "print(f\"  Rango de medias por fBO4: {range_fbo4:.2f}s\")\n",
    "print(f\"  Rango de medias por S/G:  {range_sg:.2f}s\")\n",
    "print()\n",
    "if range_sg > range_fbo4:\n",
    "    print(\"  → S/G es el driver DOMINANTE de t_gen\")\n",
    "    print(\"    La diversidad monomérica determina la accesibilidad computacional\")\n",
    "elif range_fbo4 > range_sg:\n",
    "    print(\"  → fBO4 es el driver DOMINANTE de t_gen\")\n",
    "    print(\"    La arquitectura de enlace determina la accesibilidad computacional\")\n",
    "else:\n",
    "    print(\"  → Ambos factores contribuyen por igual → hay interacción\")"
   ]
  }
